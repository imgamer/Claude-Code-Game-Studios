{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(./Build/*)",
      "Bash(./RunUAT*)",
      "Bash(Engine/Binaries/*)",
      "Bash(Engine/Build/BatchFiles/*)",
      "Bash(python*automation*)",
      "Bash(python*script*)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Read(Source/**)",
      "Read(Content/**)",
      "Read(Plugins/**)",
      "Read(Config/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout -- *)",
      "Bash(git restore .)",
      "Bash(sudo *)",
      "Bash(chmod 777*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Read(**/.env*)",
      "Read(**/.env)",
      "Read(**/Saved/**)",
      "Read(**/Intermediate/**)",
      "Read(**/DerivedDataCache/**)",
      "Read(**/.git/**)",
      "Write(Engine/**)",
      "Write(Plugins/Marketplace/**)",
      "Write(Content/**/Saved/**)",
      "Write(**/.git/**)",
      "Edit(Engine/**)",
      "Edit(Plugins/Marketplace/**)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/log-agent.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/log-agent-stop.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-commit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-push.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-start.sh" }
        ]
      }
    ],
    "SessionStop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-stop.sh" }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-compact.sh" }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-compact.sh" }
        ]
      }
    ]
  }
}
